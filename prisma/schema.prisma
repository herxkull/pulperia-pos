generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id              Int               @id @default(autoincrement())
  barcode         String?           @unique
  name            String
  price           Float
  cost            Float
  stock           Int
  minStock        Int               @default(5)
  unit            String            @default("Unidad") // Unidad, Libra, Litro, etc. (Deprecating in favor of unitName/packageName)
  unitName        String            @default("Unidad")
  packageName     String            @default("Paquete")
  unitsPerPackage Int               @default(1)
  wholesalePrice  Float?
  expiryDate      DateTime?
  
  categoryId      Int?
  category        Category?         @relation(fields: [categoryId], references: [id])
  
  supplierId      Int?
  supplier        Supplier?         @relation(fields: [supplierId], references: [id])
  
  sales           SaleItem[]
  purchases       PurchaseItem[]
  adjustments     StockAdjustment[]
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String?
  email     String?
  address   String?
  visitDay  String?    // Lunes, Martes, etc.
  products  Product[]
  purchases Purchase[]
}

model Customer {
  id             Int               @id @default(autoincrement())
  name           String
  phone          String?
  creditLimit    Float             @default(0)
  currentDebt    Float             @default(0)
  sales          Sale[]
  payments       CustomerPayment[]
  creditPayments CreditPayment[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model CustomerPayment {
  id         Int      @id @default(autoincrement())
  amount     Float
  date       DateTime @default(now())
  method     String   @default("Efectivo") // Efectivo, Transferencia
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
}

model CreditPayment {
  id         Int      @id @default(autoincrement())
  amount     Float
  date       DateTime @default(now())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
  shiftId    Int
  shift      Shift    @relation(fields: [shiftId], references: [id])
}

model Sale {
  id            Int        @id @default(autoincrement())
  ticketNumber  String?    @unique
  total         Float
  date          DateTime   @default(now())
  paymentMethod String     @default("CASH") // CASH, CARD, TRANSFER, CREDIT
  status        String     @default("COMPLETED") // COMPLETED, VOIDED, SUSPENDED
  customerId    Int?
  customer      Customer?  @relation(fields: [customerId], references: [id])
  shiftId       Int?
  shift         Shift?     @relation(fields: [shiftId], references: [id])
  items         SaleItem[]
}

model SaleItem {
  id        Int      @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Int
  price     Float
  sale      Sale     @relation(fields: [saleId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model StockAdjustment {
  id        Int      @id @default(autoincrement())
  productId Int
  quantity  Int      // Puede ser positivo o negativo
  reason    String   // Daño, Vencimiento, Autoconsumo, Ajuste Manual
  date      DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model Shift {
  id             Int             @id @default(autoincrement())
  openedAt       DateTime        @default(now())
  closedAt       DateTime?
  startingCash   Float           @default(0)
  expectedCash   Float           @default(0)
  actualCash     Float?
  status         String          @default("OPEN") // OPEN, CLOSED
  sales          Sale[]
  expenses       Expense[]
  creditPayments CreditPayment[]
}

model Expense {
  id          Int       @id @default(autoincrement())
  description String
  amount      Float
  date        DateTime  @default(now())
  category    String    @default("OPERATIONAL_EXPENSE") // INVENTORY_PURCHASE, OPERATIONAL_EXPENSE
  subCategory String?
  purchaseId  Int?
  purchase    Purchase? @relation(fields: [purchaseId], references: [id])
  shiftId     Int
  shift       Shift     @relation(fields: [shiftId], references: [id])
}

model Purchase {
  id         Int            @id @default(autoincrement())
  date       DateTime       @default(now())
  totalCost  Float
  supplierId Int?
  supplier   Supplier?      @relation(fields: [supplierId], references: [id])
  items      PurchaseItem[]
  expenses   Expense[]
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  productId  Int
  quantity   Int
  unitCost   Float
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  product    Product  @relation(fields: [productId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("ADMIN") // ADMIN, CASHIER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 