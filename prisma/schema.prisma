generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Store {
  id               String            @id @default(cuid())
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  isActive         Boolean           @default(true)
  products         Product[]
  categories       Category[]
  suppliers        Supplier[]
  customers        Customer[]
  customerPayments CustomerPayment[]
  creditPayments   CreditPayment[]
  sales            Sale[]
  saleItems        SaleItem[]
  stockAdjustments StockAdjustment[]
  shifts           Shift[]
  expenses         Expense[]
  purchases        Purchase[]
  purchaseItems    PurchaseItem[]
  users            User[]
}

model Product {
  id              Int               @id @default(autoincrement())
  storeId         String
  barcode         String?
  name            String
  price           Float
  cost            Float
  stock           Int
  minStock        Int               @default(5)
  unit            String            @default("Unidad")
  unitName        String            @default("Unidad")
  packageName     String            @default("Paquete")
  unitsPerPackage Int               @default(1)
  wholesalePrice  Float?
  expiryDate      DateTime?
  categoryId      Int?
  supplierId      Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplier        Supplier?         @relation(fields: [supplierId], references: [id])
  category        Category?         @relation(fields: [categoryId], references: [id])
  purchases       PurchaseItem[]
  sales           SaleItem[]
  adjustments     StockAdjustment[]

  @@unique([storeId, barcode])
  @@index([storeId])
}

model Category {
  id       Int       @id @default(autoincrement())
  storeId  String
  name     String
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([storeId, name])
  @@index([storeId])
}

model Supplier {
  id        Int        @id @default(autoincrement())
  storeId   String
  name      String
  phone     String?
  email     String?
  address   String?
  visitDay  String?
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products  Product[]
  purchases Purchase[]

  @@index([storeId])
}

model Customer {
  id             Int               @id @default(autoincrement())
  storeId        String
  name           String
  phone          String?
  creditLimit    Float             @default(0)
  currentDebt    Float             @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  store          Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  creditPayments CreditPayment[]
  payments       CustomerPayment[]
  sales          Sale[]

  @@index([storeId])
}

model CustomerPayment {
  id         Int      @id @default(autoincrement())
  storeId    String
  amount     Float
  date       DateTime @default(now())
  method     String   @default("Efectivo")
  customerId Int
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([storeId])
}

model CreditPayment {
  id         Int      @id @default(autoincrement())
  storeId    String
  amount     Float
  date       DateTime @default(now())
  customerId Int
  shiftId    Int
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shift      Shift    @relation(fields: [shiftId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])

  @@index([storeId])
}

model Sale {
  id             Int        @id @default(autoincrement())
  storeId        String
  ticketNumber   String?
  total          Float
  date           DateTime   @default(now())
  paymentMethod  String     @default("CASH")
  status         String     @default("COMPLETED")
  customerId     Int?
  shiftId        Int?
  receivedAmount Float?
  store          Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shift          Shift?     @relation(fields: [shiftId], references: [id])
  customer       Customer?  @relation(fields: [customerId], references: [id])
  items          SaleItem[]

  @@unique([storeId, ticketNumber])
  @@index([storeId])
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  storeId   String
  saleId    Int
  productId Int
  quantity  Int
  price     Float
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  sale      Sale    @relation(fields: [saleId], references: [id])

  @@index([storeId])
}

model StockAdjustment {
  id        Int      @id @default(autoincrement())
  storeId   String
  productId Int
  quantity  Int
  reason    String
  date      DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id])

  @@index([storeId])
}

model Shift {
  id             Int             @id @default(autoincrement())
  storeId        String
  openedAt       DateTime        @default(now())
  closedAt       DateTime?
  startingCash   Float           @default(0)
  expectedCash   Float           @default(0)
  actualCash     Float?
  status         String          @default("OPEN")
  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  creditPayments CreditPayment[]
  expenses       Expense[]
  sales          Sale[]

  @@index([storeId])
}

model Expense {
  id          Int       @id @default(autoincrement())
  storeId     String
  description String
  amount      Float
  date        DateTime  @default(now())
  category    String    @default("OPERATIONAL_EXPENSE")
  purchaseId  Int?
  shiftId     Int
  subCategory String?
  store       Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shift       Shift     @relation(fields: [shiftId], references: [id])
  purchase    Purchase? @relation(fields: [purchaseId], references: [id])

  @@index([storeId])
}

model Purchase {
  id         Int            @id @default(autoincrement())
  storeId    String
  date       DateTime       @default(now())
  totalCost  Float
  supplierId Int?
  store      Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  expenses   Expense[]
  supplier   Supplier?      @relation(fields: [supplierId], references: [id])
  items      PurchaseItem[]

  @@index([storeId])
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  storeId    String
  purchaseId Int
  productId  Int
  quantity   Int
  unitCost   Float
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
  purchase   Purchase @relation(fields: [purchaseId], references: [id])

  @@index([storeId])
}

model User {
  id        Int      @id @default(autoincrement())
  storeId   String
  username  String
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, username])
  @@index([storeId])
}
